# Backend Environment Variables
# Copy this file to .env and fill in the values for local development
# For production (Render), set these in the Render dashboard Environment tab

# Django Secret Key — generate a strong random key for production
# Run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY='django-insecure-your-secret-key-here'

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hostnames (no spaces)
# Example for Render: hostel-backend.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — set to False in production and list your frontend URL below
CORS_ALLOW_ALL_ORIGINS=True
# Comma-separated list of allowed frontend origins (used when CORS_ALLOW_ALL_ORIGINS=False)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Email Configuration (SMTP via Gmail)
# For Gmail: Create an App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST_USER='your-email@gmail.com'
EMAIL_HOST_PASSWORD='your-app-password'

# Frontend URL (used in password-reset email links)
# Change to your Netlify/Vercel URL in production
FRONTEND_URL='http://localhost:5173'
